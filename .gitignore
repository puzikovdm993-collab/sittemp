dist/
build/
target/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.py.class
.Python
env/
venv/
.venv/
.eggs/
.egg-info/
*.egg
*.egg-info/

# Logs
*.log

# Environment variables
.env
.env.local
.env.*

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Coverage reports
coverage/
htmlcov/
.coverage

# Temporary files
*.tmp
*.temp
*.bak
*.backup

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
```